#!/usr/bin/env bash
# ============================================================================
#  PISCINE 42 - EXAM SIMULATOR : launcher un-clic
#  Usage :
#     ./examshell            -> lance en natif (macOS/Linux), le plus simple
#     ./examshell --docker   -> lance dans un conteneur Linux (IDENTIQUE au vrai exam 42)
#     ./examshell --help
# ============================================================================
set -e
cd "$(dirname "$0")"

RED=$'\033[1;31m'; GRN=$'\033[1;32m'; YLW=$'\033[1;33m'; CYN=$'\033[1;36m'; RST=$'\033[0m'
say()  { printf '%s\n' "$*"; }
info() { printf '%s==>%s %s\n' "$CYN" "$RST" "$*"; }
warn() { printf '%s[!]%s %s\n' "$YLW" "$RST" "$*"; }
die()  { printf '%s[stop]%s %s\n' "$RED" "$RST" "$*" >&2; exit 1; }

usage() {
    cat <<EOF
${GRN}Piscine 42 - Exam Simulator${RST}

  ./examshell            Lance l'exam en natif (macOS/Linux). Le plus simple.
  ./examshell --docker   Lance dans un conteneur Linux, IDENTIQUE au vrai exam 42
                         (gcc Linux + mêmes outils). Recommandé si le natif coince.
  ./examshell --help     Affiche ceci.

Dans l'exam : tu tapes ton code dans le dossier ${YLW}rendu/<exo>/<exo>.c${RST},
puis 'test' pour te faire corriger, 'next' pour changer d'exo, 'exit' pour sortir.
EOF
}

run_docker() {
    command -v docker >/dev/null 2>&1 || die "Docker n'est pas installé. Installe Docker Desktop, ou lance sans --docker (mode natif)."
    docker info >/dev/null 2>&1 || die "Le démon Docker ne tourne pas. Ouvre Docker Desktop puis réessaie."
    local img="piscine42-examshell"
    if ! docker image inspect "$img" >/dev/null 2>&1; then
        info "Première fois : construction de l'image Linux (gcc + outils)... (~1 min)"
        docker build -t "$img" . || die "docker build a échoué."
    fi
    info "Environnement Linux identique à l'exam 42. C'est parti."
    exec docker run --rm -it -v "$PWD":/exam -w /exam "$img" bash exam.sh
}

run_native() {
    # Il faut un compilateur C. gcc, sinon on fait un shim vers cc/clang.
    if ! command -v gcc >/dev/null 2>&1; then
        if command -v cc >/dev/null 2>&1; then
            mkdir -p .bin
            ln -sf "$(command -v cc)" .bin/gcc
            export PATH="$PWD/.bin:$PATH"
            warn "gcc absent : on utilise cc/clang à la place (ok pour la piscine)."
        else
            die "Aucun compilateur C trouvé. Sur Mac : lance '${YLW}xcode-select --install${RST}' puis réessaie. (Ou utilise ./examshell --docker)"
        fi
    fi
    # bash trop vieux (macOS = 3.2) : les scripts sont compatibles, on prévient juste.
    if [ -n "${BASH_VERSINFO:-}" ] && [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
        warn "bash ${BASH_VERSION} (ancien) détecté : ok ici. Si un affichage bug, essaie ./examshell --docker."
    fi
    exec bash exam.sh
}

case "${1:-}" in
    --help|-h) usage ;;
    --docker)  run_docker ;;
    "")        run_native ;;
    *)         die "Option inconnue : $1 (voir ./examshell --help)" ;;
esac
